
---
import BaseLayout from '@core/layouts/BaseLayout.astro';
---


<BaseLayout title={Astro.props.title} description={Astro.props.description}>
  <!-- Add custom header content -->
  <div slot="header-extra" class="user-header">
    <p>Custom header content</p>
  </div>

  <!-- Main content from slot -->
  <slot />

  <!-- Add custom footer content -->
  <div slot="footer-extra" class="user-footer">
    <p>Custom footer content</p>
  </div>
</BaseLayout>

<style>
  .user-header, .user-footer {
    padding: 1rem;
    text-align: center;
  }
</style>
