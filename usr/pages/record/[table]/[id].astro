---
import { getRecordFromParams } from '@core/utils/record-fetcher';
import BaseLayout from '../../../layouts/BaseLayout.astro';

export const prerender = false;

const record = await getRecordFromParams(Astro);
const { table, id } = Astro.params;
---

<BaseLayout title={record?.Site_Name}>
  
  {record ? (
    <div class="container py-4">
      <div class="row g-4">
        
        <!-- Site Name - Full width -->
        <div class="col-12">
          <h1 class="display-4 fw-bold mb-3">
            {record.Site_Name || `Record ${id}`}
          </h1>
          <p class="small text-secondary mb-4">
            Table: {Astro.params.table} | ID: {Astro.params.id}
          </p>
        </div>
        
        <!-- Description Column -->
        <div class="col-12 col-md-6">
          <h2 class="h4 fw-semibold mb-2">Description</h2>
          <p class="text-body">
            {record.Description || 'No description available'}
          </p>
          
          <div class="mt-4">
            <h3 class="h5 fw-medium mb-2">Additional Info</h3>
            <p class="small text-secondary">
              Survey Year: {record.Survey_Year || 'N/A'}
            </p>
            <p class="small text-secondary">
              Creator: {record.Creator || 'N/A'}
            </p>
          </div>
        </div>
        
        <!-- Location Column -->
        <div class="col-12 col-md-6">
          <h2 class="h4 fw-semibold mb-2">Location</h2>
          <div class="vstack gap-2">
            {(record.Latitude && record.Longitude) && (
              <div class="font-monospace small">
                <span class="fw-semibold">Coordinates:</span> 
                {record.Latitude}, {record.Longitude}
              </div>
            )}
            <div class="small text-secondary">
              <span class="fw-semibold">Context:</span> {record.Context_3 || 'N/A'}
            </div>
            <div class="small text-secondary">
              <span class="fw-semibold">Setting:</span> {record.Setting || 'N/A'}
            </div>
          </div>
          
          <!-- Thumbnail if available -->
          {record.Thumbnail && (
            <div class="mt-3">
              <img 
                src={record.Thumbnail} 
                alt="Site thumbnail"
                class="img-fluid rounded shadow"
              />
            </div>
          )}
        </div>
        
        <!-- Additional sections -->
        <div class="col-12 mt-4">
          <h2 class="h4 fw-semibold mb-3">Site Details</h2>
          <div class="row g-3 small">
            <div class="col-12 col-md-4">
              <span class="fw-semibold">Item Category:</span> {record.Item_Category || 'N/A'}
            </div>
            <div class="col-12 col-md-4">
              <span class="fw-semibold">Site Number:</span> {record.Site_Number || 'N/A'}
            </div>
            <div class="col-12 col-md-4">
              <span class="fw-semibold">Survey Date:</span> {record.Survey_Date || 'N/A'}
            </div>
          </div>
          
          {record.Site_Description && (
            <div class="mt-3">
              <h3 class="fw-semibold mb-2">Site Description</h3>
              <p class="text-body small">
                {record.Site_Description}
              </p>
            </div>
          )}
        </div>
        
      </div>
    </div>
  ) : (
    <div class="container py-4">
      <div class="alert alert-danger" role="alert">
        <div class="fw-semibold mb-2">
          Record Not Found
        </div>
        <div class="small">
          No record found for table "{table}" with ID "{id}"
        </div>
      </div>
    </div>
  )}

</BaseLayout>