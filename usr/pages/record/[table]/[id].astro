---
import { getRecordFromParams } from '@core/utils/record-fetcher';
import BaseLayout from '../../../layouts/BaseLayout.astro';

export const prerender = false;

const { table, id } = Astro.params;

// Reject requests for static files (IDs with extensions or path separators)
if (!id || id.includes('.') || id.includes('/')) {
  return Astro.redirect('/404');
}

const record = await getRecordFromParams(Astro);

// Import all record templates
const templates = import.meta.glob<any>('../../../layouts/record/*.astro', { eager: true });

// Try to find table-specific template, fallback to default
let Template: any = null;
for (const [path, module] of Object.entries(templates)) {
  const filename = path.split('/').pop()?.replace('.astro', '');
  if (filename === table) {
    Template = module.default;
    break;
  }
  if (filename === 'default' && !Template) {
    Template = module.default;
  }
}
---

<BaseLayout title={record?.title || record?.Site_Name || `Record ${id}`}>
  {record && Template ? (
    <Template record={record} table={table} id={id} />
  ) : (
    <div class="container py-4">
      <div class="alert alert-danger" role="alert">
        <div class="fw-semibold mb-2">Record Not Found</div>
        <div class="small">
          No record found for table "{table}" with ID "{id}"
        </div>
      </div>
    </div>
  )}
</BaseLayout>
